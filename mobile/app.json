{
  "expo": {
    "name": "Reverie",
    "slug": "reverie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reverie",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F4F2EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "apiUrl": "https://reverie-6acv.onrender.com/api/v1",
      "router": {},
      "eas": {
        "projectId": "0ad101e3-5d6c-4524-a1a1-f52c2416a987"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.reverie.journal",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock your journal",
        "NSCameraUsageDescription": "Take photos for journal entries",
        "NSPhotoLibraryUsageDescription": "Choose photos for journal entries"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4F2EE"
      },
      "package": "app.reverie.journal",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Reverie needs access to choose photos for your journal."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
