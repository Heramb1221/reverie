{
  "expo": {
    "name": "Reverie",
    "slug": "reverie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reverie",
    "userInterfaceStyle": "automatic",
    "splash": { "backgroundColor": "#F4F2EE" },
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "apiUrl": "http://localhost:5000/api/v1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.reverie.journal",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock your journal",
        "NSCameraUsageDescription": "Take photos for journal entries",
        "NSPhotoLibraryUsageDescription": "Choose photos for journal entries"
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#F4F2EE" },
      "package": "app.reverie.journal",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-image-picker",
        { "photosPermission": "Reverie needs access to choose photos for your journal." }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
